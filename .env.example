# Copy to `.env` and fill. Do not commit real secrets.
# For Cloud Run, use Secret Manager; local uses Docker Postgres (see `scripts/ensure-postgres.mjs`).

# -----------------------------------------------------------------------------
# Postgres (local default: postgres/postgres, db `vi`, port 5432)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vi

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=3001
VI_DEBUG_CONTEXT=false
VI_CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
VI_REQUIRE_API_KEY=false
VI_PUBLIC_API_KEY=
VI_OWNER_API_KEY=
VI_GUEST_MESSAGE_LIMIT=8
VI_OWNER_EXTERNAL_ID=owner:yourhandle
VI_OVERRIDE_STRING_NAME=

# -----------------------------------------------------------------------------
# Autonomy
# -----------------------------------------------------------------------------
VI_AUTONOMY_ENABLED=true
VI_AUTONOMY_KILL_SWITCH=false
VI_AUTONOMY_ALLOW_LOCAL_READ=true
VI_AUTONOMY_ALLOW_LOCAL_WRITE_SAFE=true
VI_AUTONOMY_ALLOW_EXTERNAL_NOTIFY=true
VI_AUTONOMY_ALLOW_EXTERNAL_ACT=true
VI_AUTONOMY_PING_MIN_INTERVAL_MS=600000
VI_AUTONOMY_MIN_RELEVANCE=medium
VI_AUTONOMY_NOTIFY_WEBHOOK_URL=
VI_AUTONOMY_NOTIFY_WEBHOOK_SECRET=
VI_AUTONOMY_ACT_WEBHOOK_URL=
VI_AUTONOMY_ACT_WEBHOOK_SECRET=
VI_AUTONOMY_WEBHOOK_RETRIES=2
VI_AUTONOMY_WEBHOOK_BACKOFF_MS=300

# -----------------------------------------------------------------------------
# Weather (optional) — e.g. "Austin TX"
# -----------------------------------------------------------------------------
VI_WEATHER_LOCATION=
VI_SYSTEM_PROMPT_BUDGET=
VI_USER_TIMEZONE=
VI_STRICT_SOURCE_MODE=true

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# openai | xai | gemini | vertexai
VI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_EVALUATIVE=gpt-4o

XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
XAI_MODEL_EVALUATIVE=grok-4-fast-reasoning

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_EVALUATIVE=gemini-2.5-pro

# Vertex (ADC or GOOGLE_APPLICATION_CREDENTIALS; project must have Vertex / billing)
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1
VERTEXAI_MODEL=gemini-2.5-flash
VERTEXAI_MODEL_EVALUATIVE=gemini-2.5-pro
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

OLLAMA_BASE_URL=http://127.0.0.1:11434

# -----------------------------------------------------------------------------
# Web (browser) — `NEXT_PUBLIC_*` must not be the owner key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_VI_API_KEY=
NEXT_PUBLIC_ACTOR_EXTERNAL_ID=owner:yourhandle
