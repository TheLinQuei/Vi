# Copy to `.env` and fill. Do not commit real secrets.
# For Cloud Run, use Secret Manager; local uses Docker Postgres (see `scripts/ensure-postgres.mjs`).

# -----------------------------------------------------------------------------
# Postgres (local default: postgres/postgres, db `vi`, port 5432)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vi

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=3001
VI_DEBUG_CONTEXT=false
VI_CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
VI_REQUIRE_API_KEY=false
VI_PUBLIC_API_KEY=
VI_OWNER_API_KEY=
VI_GUEST_MESSAGE_LIMIT=8
VI_OWNER_EXTERNAL_ID=owner:yourhandle
VI_OWNER_EMAIL=
VI_SESSION_COOKIE_NAME=vi_session
VI_SESSION_TTL_HOURS=720
VI_SESSION_SECURE=true
VI_GOOGLE_CLIENT_ID=
VI_GOOGLE_CLIENT_SECRET=
VI_GOOGLE_REDIRECT_URI=
# Owner-only override codeword (e.g. Violet). Not a display name for chat — Discord wake is **Vi** in Vigil.
# Must match Vigil `VIGIL_OWNER_OVERRIDE_STRING_NAME` exactly (case-sensitive). Empty = override disabled.
VI_OVERRIDE_STRING_NAME=

# -----------------------------------------------------------------------------
# Autonomy
# -----------------------------------------------------------------------------
VI_AUTONOMY_ENABLED=true
VI_AUTONOMY_KILL_SWITCH=false
VI_AUTONOMY_ALLOW_LOCAL_READ=true
VI_AUTONOMY_ALLOW_LOCAL_WRITE_SAFE=true
VI_AUTONOMY_ALLOW_EXTERNAL_NOTIFY=true
VI_AUTONOMY_ALLOW_EXTERNAL_ACT=true
VI_AUTONOMY_PING_MIN_INTERVAL_MS=600000
VI_AUTONOMY_MIN_RELEVANCE=medium
VI_RUNTIME_PROFILE=balanced
# smart_core = intelligence-first profile: disables proactive pings + passive mention injection + soft style wrappers
# VI_RUNTIME_PROFILE=smart_core
VI_ALLOW_PROACTIVE_PINGS=true
VI_INCLUDE_PASSIVE_PENDING_MENTION=true
# Allow guest `/chat` to use OSS lane when `context.vi.preferOpenWeights` / routing.lane is set (owner always allowed).
VI_OSS_ALLOW_GUEST=false
# Optional media tool executor webhook for TOOL_ENVELOPE dispatch (`media.generate_image` / `media.generate_video`)
VI_MEDIA_TOOL_WEBHOOK_URL=
VI_MEDIA_TOOL_WEBHOOK_SECRET=
# Optional search tool executor webhook for TOOL_ENVELOPE dispatch (`web.search` / `docs.search`)
VI_SEARCH_TOOL_WEBHOOK_URL=
VI_SEARCH_TOOL_WEBHOOK_SECRET=
VI_AUTONOMY_NOTIFY_WEBHOOK_URL=
VI_AUTONOMY_NOTIFY_WEBHOOK_SECRET=
VI_AUTONOMY_ACT_WEBHOOK_URL=
VI_AUTONOMY_ACT_WEBHOOK_SECRET=
VI_AUTONOMY_WEBHOOK_RETRIES=2
VI_AUTONOMY_WEBHOOK_BACKOFF_MS=300

# -----------------------------------------------------------------------------
# Weather (optional) — e.g. "Austin TX"
# -----------------------------------------------------------------------------
VI_WEATHER_LOCATION=
VI_SYSTEM_PROMPT_BUDGET=
VI_USER_TIMEZONE=
VI_STRICT_SOURCE_MODE=true

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# openai | xai | gemini | vertexai
VI_PROVIDER=openai
VI_MODEL_ROUTER_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_EVALUATIVE=gpt-4o
OPENAI_MODEL_REASONING=
OPENAI_MODEL_CODE=
OPENAI_MODEL_CREATIVE=

XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
XAI_MODEL_EVALUATIVE=grok-4-fast-reasoning
XAI_MODEL_REASONING=
XAI_MODEL_CODE=
XAI_MODEL_CREATIVE=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_EVALUATIVE=gemini-2.5-pro
GEMINI_MODEL_REASONING=
GEMINI_MODEL_CODE=
GEMINI_MODEL_CREATIVE=
# Optional vision/multimodal tier when `discord.imageUrls` / `vi.multimodal.imageUrls` are present (defaults to base model if unset)
GEMINI_MODEL_VISION=

# Vertex (ADC or GOOGLE_APPLICATION_CREDENTIALS; project must have Vertex / billing)
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1
VERTEXAI_MODEL=gemini-2.5-flash
VERTEXAI_MODEL_EVALUATIVE=gemini-2.5-pro
VERTEXAI_MODEL_REASONING=
VERTEXAI_MODEL_CODE=
VERTEXAI_MODEL_CREATIVE=
VERTEXAI_MODEL_VISION=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional vision tier for OpenAI / XAI when images are attached (defaults to base model)
OPENAI_MODEL_VISION=
XAI_MODEL_VISION=

# OpenAI-compatible “open weights” lane (vLLM, LiteLLM, Ollama bridge). Routed when context requests it — see VI_OSS_ALLOW_GUEST in apps/api env.
VI_OSS_BASE_URL=
VI_OSS_API_KEY=
VI_OSS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Multimodal URL fetch guard (Vertex native path fetches HTTPS images; Discord CDN allowed by default)
VI_MULTIMODAL_FETCH_MAX_BYTES=4194304
# VI_MULTIMODAL_URL_ALLOWLIST=cdn.discordapp.com,media.discord.net

OLLAMA_BASE_URL=http://127.0.0.1:11434

# -----------------------------------------------------------------------------
# Web (browser) — `NEXT_PUBLIC_*` must not be the owner key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_VI_API_KEY=
NEXT_PUBLIC_ACTOR_EXTERNAL_ID=guest:public
NEXT_PUBLIC_GUEST_MESSAGE_LIMIT=8
